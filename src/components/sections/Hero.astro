---
---

<section id="hero" class="min-h-screen flex items-center justify-center pt-16">
  <div class="container-custom text-center">
    <div class="animate-fade-in-up">
      <p class="text-primary-600 dark:text-primary-400 font-medium mb-2">
        Hello, I'm
      </p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-dark-900 dark:text-light mb-6">
        Your Name
      </h1>
      <h2 class="text-2xl md:text-3xl text-dark-600 dark:text-dark-400 mb-8">
        Front End Engineer
      </h2>
      <p class="text-lg text-dark-600 dark:text-dark-400 max-w-2xl mx-auto mb-10">
        I build accessible, pixel-perfect, and performant web experiences.
        Passionate about React, Astro, and creating intuitive user interfaces.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="#projects"
          class="btn-primary"
        >
          View Projects
        </a>
        <a
          href="#contact"
          class="btn-secondary"
        >
          Contact Me
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce-subtle">
      <a
        href="#about"
        class="text-dark-400 dark:text-dark-500 hover:text-primary-600 dark:hover:text-primary-400 transition-colors"
        aria-label="Scroll to about section"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"
          />
        </svg>
      </a>
    </div>
  </div>
</section>
